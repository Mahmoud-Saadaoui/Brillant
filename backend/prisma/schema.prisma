// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CANDIDATE
  RECRUITER
  ADMIN
}

enum JobType {
  CDI
  CDD
  STAGE
  FREELANCE
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum Gender {
  MALE
  FEMALE
}

enum Availability {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum LanguageLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
  FLUENT
  NATIVE
}


model User {
  id                Int    @id @default(autoincrement())
  name              String
  email             String    @unique
  password          String
  role              Role    @default(CANDIDATE)
  isAccountVerified Boolean @default(false)
  gender            Gender?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  verificationTokens VerificationToken[]
  // Profiles relations
  candidateProfile  CandidateProfile?
  recruiterProfile  RecruiterProfile?
}

model VerificationToken {
  id        Int   @id @default(autoincrement()) 
  userId    Int   @unique 
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecruiterProfile {
  id        Int    @id @default(autoincrement())
  userId    Int    @unique
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Entreprise
  companyName        String
  companyDescription String?
  companySize        String?    // ex: "1-10", "11-50", "50+"
  industry           String?
  logo               String?
  logoPublicId       String?    // Cloudinary public ID for deletion
  location           String?

  // Contact
  phone              String?
  website            String?
  socialMedia        Json?      // {linkedin, twitter, facebook}
  socialLinks        Json?      // {linkedin, twitter, facebook, github, website}

  // Relations
  jobs               Job[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model CandidateProfile {
  id                Int    @id @default(autoincrement())
  userId            Int    @unique
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Informations de base
  avatarUrl         String?
  avatarPublicId    String?               // Cloudinary public ID for deletion
  title             String?              // ex: Full-Stack Developer
  bio               String?
  location          String?

  // Disponibilité et salaire
  availability      Availability[]
  expectedSalaryMin Int?
  expectedSalaryMax Int?

  // Compétences
  skills            String[]
  softSkills        String[]

  // Réseaux sociaux
  socialLinks       Json?                // {linkedin, github, portfolio, website}

  // CV
  cvUrl             String?
  cvPublicId        String?               // Cloudinary public ID for deletion

  // IA (futur)
  embeddingId       Int?

  // Relations
  experiences       Experience[]
  education         Education[]
  languages         Language[]
  applications      Application[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Experience {
  id          Int              @id @default(autoincrement())
  candidateId Int
  profile     CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  title       String            // ex: Senior Developer
  company     String
  location    String?
  startDate   DateTime
  endDate     DateTime?         // null si emploi actuel
  description String?
  current     Boolean          @default(false)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Education {
  id          Int              @id @default(autoincrement())
  candidateId Int
  profile     CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  degree      String            // ex: Master en Informatique
  school      String            // ex: Université Paris-Saclay
  field       String?           // ex: Informatique
  startDate   DateTime
  endDate     DateTime?
  description String?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Language {
  id          Int              @id @default(autoincrement())
  candidateId Int
  profile     CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  language    String            // ex: Anglais
  level       LanguageLevel

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Job {
  id          Int              @id @default(autoincrement())
  recruiterId Int
  recruiter   RecruiterProfile @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  title       String
  description String
  location    String?
  jobType     JobType
  salaryMin   Int?
  salaryMax   Int?

  skills      String[]

  applications Application[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Application {
  id          Int              @id @default(autoincrement())
  jobId       Int
  job         Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId Int
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  status      ApplicationStatus @default(PENDING)
  coverLetter String?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([jobId, candidateId])
}